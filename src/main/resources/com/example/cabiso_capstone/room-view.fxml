<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cabiso_capstone.controllers.RoomController"
            prefWidth="1100.0"
            prefHeight="700.0"
            stylesheets="@styles.css"
            styleClass="management-root">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15.0"
              styleClass="dashboard-header">

            <padding>
                <Insets top="15.0"
                        right="25.0"
                        bottom="15.0"
                        left="25.0"/>
            </padding>

            <VBox spacing="2.0">
                <Label text="CABANA DORMITORY"
                       styleClass="dashboard-brand"/>

                <Label text="Dormitory Management System"
                       styleClass="dashboard-brand-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2.0">

                <Label text="Administrator"
                       styleClass="dashboard-user"/>

                <Label text="System Manager"
                       styleClass="dashboard-user-role"/>
            </VBox>

        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0"
              spacing="8.0"
              styleClass="dashboard-sidebar">

            <padding>
                <Insets top="28.0"
                        right="15.0"
                        bottom="22.0"
                        left="15.0"/>
            </padding>

            <Label text="MAIN MENU"
                   styleClass="sidebar-title"/>

            <Button text="Dashboard"
                    maxWidth="Infinity"
                    onAction="#openDashboard"
                    styleClass="sidebar-button"/>

            <Button text="Tenant Management"
                    maxWidth="Infinity"
                    onAction="#openTenantView"
                    styleClass="sidebar-button"/>

            <Button text="Room Management"
                    maxWidth="Infinity"
                    styleClass="sidebar-button-active"/>

            <Button text="Payment Management"
                    maxWidth="Infinity"
                    onAction="#openPaymentView"
                    styleClass="sidebar-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout"
                    maxWidth="Infinity"
                    onAction="#handleLogout"
                    styleClass="logout-button"/>

        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="management-scroll-pane">

            <content>
                <VBox spacing="20.0"
                      styleClass="management-content">

                    <padding>
                        <Insets top="30.0"
                                right="32.0"
                                bottom="35.0"
                                left="32.0"/>
                    </padding>

                    <!-- PAGE TITLE -->
                    <VBox spacing="4.0">
                        <Label text="Room Management"
                               styleClass="dashboard-title"/>

                        <Label text="Manage room information, occupancy, rates, and availability."
                               styleClass="dashboard-subtitle"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT"
                          spacing="10.0"
                          styleClass="toolbar-card">

                        <TextField fx:id="searchField"
                                   promptText="Search by room number, status, or capacity..."
                                   prefHeight="40.0"
                                   HBox.hgrow="ALWAYS"
                                   styleClass="management-field"/>

                        <ComboBox fx:id="filterStatusComboBox"
                                  promptText="All statuses"
                                  prefWidth="150.0"
                                  prefHeight="40.0"
                                  styleClass="management-combo-box"/>

                        <Button text="Search"
                                onAction="#handleSearch"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>

                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>
                    </HBox>

                    <VBox spacing="12.0"
                          styleClass="content-card"
                          VBox.vgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT">

                            <VBox spacing="3.0">
                                <Label text="Room Records"
                                       styleClass="section-title"/>

                                <Label text="Select a room record to review or update its information."
                                       styleClass="section-description"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="recordCountLabel"
                                   text="0 records"
                                   styleClass="record-count-label"/>
                        </HBox>

                        <TableView fx:id="roomTable"
                                   prefHeight="280.0"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="management-table">

                            <placeholder>
                                <Label text="No room records available."
                                       styleClass="table-placeholder"/>
                            </placeholder>

                            <columns>
                                <TableColumn fx:id="roomIdColumn"
                                             text="Room ID"
                                             prefWidth="85.0"/>

                                <TableColumn fx:id="roomNumberColumn"
                                             text="Room Number"
                                             prefWidth="120.0"/>

                                <TableColumn fx:id="capacityColumn"
                                             text="Capacity"
                                             prefWidth="95.0"/>

                                <TableColumn fx:id="occupantsColumn"
                                             text="Occupants"
                                             prefWidth="95.0"/>

                                <TableColumn fx:id="availableSlotsColumn"
                                             text="Available Slots"
                                             prefWidth="120.0"/>

                                <TableColumn fx:id="monthlyRateColumn"
                                             text="Monthly Rate"
                                             prefWidth="130.0"/>

                                <TableColumn fx:id="statusColumn"
                                             text="Status"
                                             prefWidth="110.0"/>
                            </columns>

                        </TableView>
                    </VBox>

                    <VBox spacing="16.0"
                          styleClass="content-card">

                        <VBox spacing="3.0">
                            <Label text="Room Information"
                                   styleClass="section-title"/>

                            <Label text="Complete the required fields before saving a room record."
                                   styleClass="section-description"/>
                        </VBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Room ID"
                                       styleClass="field-label"/>

                                <TextField fx:id="roomIdField"
                                           promptText="Generated automatically"
                                           editable="false"
                                           prefHeight="40.0"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Room Number"
                                       styleClass="field-label"/>

                                <TextField fx:id="roomNumberField"
                                           promptText="Example: 101"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Capacity"
                                       styleClass="field-label"/>

                                <TextField fx:id="capacityField"
                                           promptText="Enter maximum occupants"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Current Occupants"
                                       styleClass="field-label"/>

                                <TextField fx:id="occupantsField"
                                           promptText="Enter current occupants"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Monthly Rate"
                                       styleClass="field-label"/>

                                <TextField fx:id="monthlyRateField"
                                           promptText="Enter monthly room rate"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Room Status"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="statusComboBox"
                                          promptText="Select room status"
                                          prefHeight="40.0"
                                          maxWidth="Infinity"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <Label fx:id="formMessageLabel"
                               text=""
                               wrapText="true"
                               minHeight="18.0"
                               styleClass="form-message-label"/>

                        <!-- ACTION BUTTONS -->
                        <HBox alignment="CENTER_RIGHT"
                              spacing="10.0">

                            <Button text="Clear"
                                    onAction="#handleClear"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Delete"
                                    onAction="#handleDeleteRoom"
                                    prefHeight="40.0"
                                    styleClass="danger-button"/>

                            <Button text="Update"
                                    onAction="#handleUpdateRoom"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Add Room"
                                    onAction="#handleAddRoom"
                                    prefHeight="40.0"
                                    styleClass="primary-button"/>

                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
