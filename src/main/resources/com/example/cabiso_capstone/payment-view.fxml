<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0"
            styleClass="management-root"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cabiso_capstone.controllers.PaymentController">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15.0"
              styleClass="dashboard-header">

            <padding>
                <Insets top="15.0"
                        right="25.0"
                        bottom="15.0"
                        left="25.0"/>
            </padding>

            <VBox spacing="2.0">
                <Label text="CABANA DORMITORY"
                       styleClass="dashboard-brand"/>

                <Label text="Dormitory Management System"
                       styleClass="dashboard-brand-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2.0">

                <Label text="Administrator"
                       styleClass="dashboard-user"/>

                <Label text="System Manager"
                       styleClass="dashboard-user-role"/>
            </VBox>

        </HBox>
    </top>

    <left>
        <VBox spacing="8.0"
              styleClass="dashboard-sidebar">

            <padding>
                <Insets top="28.0"
                        right="15.0"
                        bottom="22.0"
                        left="15.0"/>
            </padding>

            <Label text="MAIN MENU"
                   styleClass="sidebar-title"/>

            <Button text="Dashboard"
                    maxWidth="Infinity"
                    onAction="#openDashboard"
                    styleClass="sidebar-button"/>

            <Button text="Tenant Management"
                    maxWidth="Infinity"
                    onAction="#openTenantView"
                    styleClass="sidebar-button"/>

            <Button text="Room Management"
                    maxWidth="Infinity"
                    onAction="#openRoomView"
                    styleClass="sidebar-button"/>

            <Button text="Payment Management"
                    maxWidth="Infinity"
                    styleClass="sidebar-button-active"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout"
                    maxWidth="Infinity"
                    onAction="#handleLogout"
                    styleClass="logout-button"/>

        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="false"
                    hbarPolicy="NEVER"
                    styleClass="management-scroll-pane">

            <content>
                <VBox spacing="20.0"
                      styleClass="management-content">

                    <padding>
                        <Insets top="30.0"
                                right="32.0"
                                bottom="35.0"
                                left="32.0"/>
                    </padding>

                    <!-- Page title -->

                    <VBox spacing="4.0">
                        <Label text="Payment Management"
                               styleClass="dashboard-title"/>

                        <Label text="Record tenant payments and review transaction history."
                               styleClass="dashboard-subtitle"/>
                    </VBox>

                    <!-- Search toolbar -->

                    <HBox alignment="CENTER_LEFT"
                          spacing="10.0"
                          styleClass="toolbar-card">

                        <TextField fx:id="searchField"
                                   maxWidth="Infinity"
                                   prefHeight="40.0"
                                   promptText="Search by tenant, reference number, or billing month..."
                                   styleClass="management-field"
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="filterStatusComboBox"
                                  prefHeight="40.0"
                                  prefWidth="150.0"
                                  promptText="All Status"
                                  styleClass="management-combo-box"/>

                        <Button text="Search"
                                onAction="#handleSearch"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>

                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>

                    </HBox>

                    <!-- Payment records -->

                    <VBox minHeight="320.0"
                          prefHeight="340.0"
                          maxHeight="340.0"
                          spacing="16.0"
                          styleClass="content-card">

                        <HBox alignment="CENTER_LEFT">

                            <VBox spacing="3.0">
                                <Label text="Payment Records"
                                       styleClass="section-title"/>

                                <Label text="Select a payment record to review or update its details."
                                       styleClass="section-description"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="recordCountLabel"
                                   text="0 records"
                                   styleClass="record-count-label"/>
                        </HBox>

                        <TableView fx:id="paymentTable"
                                   minHeight="235.0"
                                   prefHeight="235.0"
                                   maxHeight="235.0"
                                   styleClass="management-table">

                            <placeholder>
                                <Label text="No payment records available."
                                       styleClass="table-placeholder"/>
                            </placeholder>

                            <columns>
                                <TableColumn fx:id="paymentIdColumn"
                                             text="ID"/>

                                <TableColumn fx:id="tenantNameColumn"
                                             text="Tenant"/>

                                <TableColumn fx:id="roomColumn"
                                             text="Room"/>

                                <TableColumn fx:id="billingMonthColumn"
                                             text="Billing Month"/>

                                <TableColumn fx:id="amountColumn"
                                             text="Amount"/>

                                <TableColumn fx:id="paymentDateColumn"
                                             text="Payment Date"/>

                                <TableColumn fx:id="paymentMethodColumn"
                                             text="Method"/>

                                <TableColumn fx:id="statusColumn"
                                             text="Status"/>
                            </columns>

                        </TableView>
                    </VBox>

                    <!-- Payment information -->

                    <VBox spacing="20.0"
                          styleClass="content-card">

                        <VBox spacing="3.0">
                            <Label text="Payment Information"
                                   styleClass="section-title"/>

                            <Label text="Select an active tenant and complete the payment details."
                                   styleClass="section-description"/>
                        </VBox>

                        <!-- Row 1 -->

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment ID"
                                       styleClass="field-label"/>

                                <TextField fx:id="paymentIdField"
                                           editable="false"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Generated automatically"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Tenant"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="tenantComboBox"
                                          maxWidth="Infinity"
                                          prefHeight="40.0"
                                          promptText="Select an active tenant"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <!-- Row 2 -->

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Assigned Room"
                                       styleClass="field-label"/>

                                <TextField fx:id="roomField"
                                           editable="false"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Loaded from selected tenant"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Billing Month"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="billingMonthComboBox"
                                          maxWidth="Infinity"
                                          prefHeight="40.0"
                                          promptText="Select billing month"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <!-- Row 3 -->

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Amount"
                                       styleClass="field-label"/>

                                <TextField fx:id="amountField"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Enter payment amount"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment Method"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="paymentMethodComboBox"
                                          maxWidth="Infinity"
                                          prefHeight="40.0"
                                          promptText="Select payment method"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <!-- Row 4 -->

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment Date"
                                       styleClass="field-label"/>

                                <DatePicker fx:id="paymentDatePicker"
                                            maxWidth="Infinity"
                                            prefHeight="40.0"
                                            promptText="Select payment date"
                                            styleClass="management-date-picker"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Current Balance"
                                       styleClass="field-label"/>

                                <TextField fx:id="currentBalanceField"
                                           editable="false"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Calculated automatically"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                        </HBox>

                        <!-- Row 5 -->

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Reference Number"
                                       styleClass="field-label"/>

                                <TextField fx:id="referenceNumberField"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Receipt or transaction reference"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment Status"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="statusComboBox"
                                          maxWidth="Infinity"
                                          prefHeight="40.0"
                                          promptText="Select payment status"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <!-- Remarks -->

                        <VBox spacing="6.0">

                            <Label text="Remarks"
                                   styleClass="field-label"/>

                            <TextArea fx:id="remarksArea"
                                      prefRowCount="3"
                                      wrapText="true"
                                      promptText="Optional notes about this payment"
                                      styleClass="management-field"/>
                        </VBox>

                        <Label fx:id="formMessageLabel"
                               minHeight="18.0"
                               text=""
                               wrapText="true"
                               styleClass="form-message-label"/>

                        <!-- Actions -->

                        <HBox alignment="CENTER_RIGHT"
                              spacing="10.0">

                            <Button text="Clear"
                                    onAction="#handleClear"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Void"
                                    onAction="#handleDeletePayment"
                                    prefHeight="40.0"
                                    styleClass="danger-button"/>

                            <Button text="Update"
                                    onAction="#handleUpdatePayment"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Record Payment"
                                    onAction="#handleRecordPayment"
                                    prefHeight="40.0"
                                    styleClass="primary-button"/>

                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>