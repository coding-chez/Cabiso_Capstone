<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cabiso_capstone.controllers.PaymentController"
            prefWidth="1100.0"
            prefHeight="700.0"
            stylesheets="@styles.css"
            styleClass="management-root">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15.0"
              styleClass="dashboard-header">

            <padding>
                <Insets top="15.0"
                        right="25.0"
                        bottom="15.0"
                        left="25.0"/>
            </padding>

            <VBox spacing="2.0">
                <Label text="CABANA DORMITORY"
                       styleClass="dashboard-brand"/>

                <Label text="Dormitory Management System"
                       styleClass="dashboard-brand-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2.0">

                <Label text="Administrator"
                       styleClass="dashboard-user"/>

                <Label text="System Manager"
                       styleClass="dashboard-user-role"/>
            </VBox>

        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0"
              spacing="8.0"
              styleClass="dashboard-sidebar">

            <padding>
                <Insets top="28.0"
                        right="15.0"
                        bottom="22.0"
                        left="15.0"/>
            </padding>

            <Label text="MAIN MENU"
                   styleClass="sidebar-title"/>

            <Button text="Dashboard"
                    maxWidth="Infinity"
                    onAction="#openDashboard"
                    styleClass="sidebar-button"/>

            <Button text="Tenant Management"
                    maxWidth="Infinity"
                    onAction="#openTenantView"
                    styleClass="sidebar-button"/>

            <Button text="Room Management"
                    maxWidth="Infinity"
                    onAction="#openRoomView"
                    styleClass="sidebar-button"/>

            <Button text="Payment Management"
                    maxWidth="Infinity"
                    styleClass="sidebar-button-active"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout"
                    maxWidth="Infinity"
                    onAction="#handleLogout"
                    styleClass="logout-button"/>

        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="management-scroll-pane">

            <content>
                <VBox spacing="20.0"
                      styleClass="management-content">

                    <padding>
                        <Insets top="30.0"
                                right="32.0"
                                bottom="35.0"
                                left="32.0"/>
                    </padding>

                    <VBox spacing="4.0">
                        <Label text="Payment Management"
                               styleClass="dashboard-title"/>

                        <Label text="Record payments and review tenant payment history."
                               styleClass="dashboard-subtitle"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT"
                          spacing="10.0"
                          styleClass="toolbar-card">

                        <TextField fx:id="searchField"
                                   promptText="Search by tenant name, payment ID, or status..."
                                   prefHeight="40.0"
                                   HBox.hgrow="ALWAYS"
                                   styleClass="management-field"/>

                        <ComboBox fx:id="filterStatusComboBox"
                                  promptText="All statuses"
                                  prefWidth="150.0"
                                  prefHeight="40.0"
                                  styleClass="management-combo-box"/>

                        <Button text="Search"
                                onAction="#handleSearch"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>

                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>
                    </HBox>

                    <VBox spacing="12.0"
                          styleClass="content-card"
                          VBox.vgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT">

                            <VBox spacing="3.0">
                                <Label text="Payment Records"
                                       styleClass="section-title"/>

                                <Label text="Select a payment record to review its details."
                                       styleClass="section-description"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="recordCountLabel"
                                   text="0 records"
                                   styleClass="record-count-label"/>
                        </HBox>

                        <TableView fx:id="paymentTable"
                                   prefHeight="280.0"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="management-table">

                            <placeholder>
                                <Label text="No payment records available."
                                       styleClass="table-placeholder"/>
                            </placeholder>

                            <columns>
                                <TableColumn fx:id="paymentIdColumn"
                                             text="Payment ID"
                                             prefWidth="95.0"/>

                                <TableColumn fx:id="tenantNameColumn"
                                             text="Tenant"
                                             prefWidth="180.0"/>

                                <TableColumn fx:id="roomColumn"
                                             text="Room"
                                             prefWidth="80.0"/>

                                <TableColumn fx:id="amountColumn"
                                             text="Amount"
                                             prefWidth="120.0"/>

                                <TableColumn fx:id="paymentDateColumn"
                                             text="Payment Date"
                                             prefWidth="130.0"/>

                                <TableColumn fx:id="paymentMethodColumn"
                                             text="Method"
                                             prefWidth="110.0"/>

                                <TableColumn fx:id="statusColumn"
                                             text="Status"
                                             prefWidth="100.0"/>
                            </columns>

                        </TableView>
                    </VBox>

                    <VBox spacing="16.0"
                          styleClass="content-card">

                        <VBox spacing="3.0">
                            <Label text="Payment Information"
                                   styleClass="section-title"/>

                            <Label text="Complete the required details before recording a payment."
                                   styleClass="section-description"/>
                        </VBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment ID"
                                       styleClass="field-label"/>

                                <TextField fx:id="paymentIdField"
                                           promptText="Generated automatically"
                                           editable="false"
                                           prefHeight="40.0"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Tenant"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="tenantComboBox"
                                          promptText="Select tenant"
                                          prefHeight="40.0"
                                          maxWidth="Infinity"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Amount"
                                       styleClass="field-label"/>

                                <TextField fx:id="amountField"
                                           promptText="Enter payment amount"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment Date"
                                       styleClass="field-label"/>

                                <DatePicker fx:id="paymentDatePicker"
                                            promptText="Select payment date"
                                            prefHeight="40.0"
                                            maxWidth="Infinity"
                                            styleClass="management-date-picker"/>
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment Method"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="paymentMethodComboBox"
                                          promptText="Select payment method"
                                          prefHeight="40.0"
                                          maxWidth="Infinity"
                                          styleClass="management-combo-box"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Payment Status"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="statusComboBox"
                                          promptText="Select payment status"
                                          prefHeight="40.0"
                                          maxWidth="Infinity"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <VBox spacing="6.0">

                            <Label text="Reference Number"
                                   styleClass="field-label"/>

                            <TextField fx:id="referenceNumberField"
                                       promptText="Enter receipt or transaction reference"
                                       prefHeight="40.0"
                                       styleClass="management-field"/>
                        </VBox>

                        <Label fx:id="formMessageLabel"
                               text=""
                               wrapText="true"
                               minHeight="18.0"
                               styleClass="form-message-label"/>

                        <HBox alignment="CENTER_RIGHT"
                              spacing="10.0">

                            <Button text="Clear"
                                    onAction="#handleClear"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Delete"
                                    onAction="#handleDeletePayment"
                                    prefHeight="40.0"
                                    styleClass="danger-button"/>

                            <Button text="Update"
                                    onAction="#handleUpdatePayment"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Record Payment"
                                    onAction="#handleRecordPayment"
                                    prefHeight="40.0"
                                    styleClass="primary-button"/>

                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
