<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cabiso_capstone.controllers.TenantController"
            prefWidth="1100.0"
            prefHeight="700.0"
            stylesheets="@styles.css"
            styleClass="management-root">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15.0"
              styleClass="dashboard-header">

            <padding>
                <Insets top="15.0"
                        right="25.0"
                        bottom="15.0"
                        left="25.0"/>
            </padding>

            <VBox spacing="2.0">
                <Label text="CABANA DORMITORY"
                       styleClass="dashboard-brand"/>

                <Label text="Dormitory Management System"
                       styleClass="dashboard-brand-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2.0">

                <Label text="Administrator"
                       styleClass="dashboard-user"/>

                <Label text="System Manager"
                       styleClass="dashboard-user-role"/>
            </VBox>

        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0"
              spacing="8.0"
              styleClass="dashboard-sidebar">

            <padding>
                <Insets top="28.0"
                        right="15.0"
                        bottom="22.0"
                        left="15.0"/>
            </padding>

            <Label text="MAIN MENU"
                   styleClass="sidebar-title"/>

            <Button text="Dashboard"
                    maxWidth="Infinity"
                    onAction="#openDashboard"
                    styleClass="sidebar-button"/>

            <Button text="Tenant Management"
                    maxWidth="Infinity"
                    styleClass="sidebar-button-active"/>

            <Button text="Room Management"
                    maxWidth="Infinity"
                    onAction="#openRoomView"
                    styleClass="sidebar-button"/>

            <Button text="Payment Management"
                    maxWidth="Infinity"
                    onAction="#openPaymentView"
                    styleClass="sidebar-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout"
                    maxWidth="Infinity"
                    onAction="#handleLogout"
                    styleClass="logout-button"/>

        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="management-scroll-pane">

            <content>
                <VBox spacing="20.0"
                      styleClass="management-content">

                    <padding>
                        <Insets top="30.0"
                                right="32.0"
                                bottom="35.0"
                                left="32.0"/>
                    </padding>

                    <VBox spacing="4.0">
                        <Label text="Tenant Management"
                               styleClass="dashboard-title"/>

                        <Label text="View, register, update, and manage dormitory tenants."
                               styleClass="dashboard-subtitle"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT"
                          spacing="10.0"
                          styleClass="toolbar-card">

                        <TextField fx:id="searchField"
                                   promptText="Search by tenant name, username, or room..."
                                   prefHeight="40.0"
                                   HBox.hgrow="ALWAYS"
                                   styleClass="management-field"/>

                        <Button text="Search"
                                onAction="#handleSearch"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>

                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>
                    </HBox>

                    <VBox spacing="12.0"
                          styleClass="content-card"
                          VBox.vgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3.0">
                                <Label text="Tenant Records"
                                       styleClass="section-title"/>

                                <Label text="Select a tenant record to view or update its information."
                                       styleClass="section-description"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="recordCountLabel"
                                   text="0 records"
                                   styleClass="record-count-label"/>
                        </HBox>

                        <TableView fx:id="tenantTable"
                                   prefHeight="280.0"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="management-table">

                            <placeholder>
                                <Label text="No tenant records available."
                                       styleClass="table-placeholder"/>
                            </placeholder>

                            <columns>
                                <TableColumn fx:id="tenantIdColumn"
                                             text="ID"
                                             prefWidth="65.0"/>

                                <TableColumn fx:id="fullNameColumn"
                                             text="Full Name"
                                             prefWidth="180.0"/>

                                <TableColumn fx:id="usernameColumn"
                                             text="Username"
                                             prefWidth="125.0"/>

                                <TableColumn fx:id="contactColumn"
                                             text="Contact Number"
                                             prefWidth="145.0"/>

                                <TableColumn fx:id="roomColumn"
                                             text="Room"
                                             prefWidth="90.0"/>

                                <TableColumn fx:id="balanceColumn"
                                             text="Balance"
                                             prefWidth="120.0"/>
                            </columns>

                        </TableView>
                    </VBox>

                    <VBox spacing="16.0"
                          styleClass="content-card">

                        <VBox spacing="3.0">
                            <Label text="Tenant Information"
                                   styleClass="section-title"/>

                            <Label text="Complete the required fields before saving a tenant record."
                                   styleClass="section-description"/>
                        </VBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Tenant ID"
                                       styleClass="field-label"/>

                                <TextField fx:id="tenantIdField"
                                           promptText="Generated automatically"
                                           editable="false"
                                           prefHeight="40.0"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Full Name"
                                       styleClass="field-label"/>

                                <TextField fx:id="fullNameField"
                                           promptText="Enter tenant's full name"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Username"
                                       styleClass="field-label"/>

                                <TextField fx:id="usernameField"
                                           promptText="Enter account username"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Password"
                                       styleClass="field-label"/>

                                <PasswordField fx:id="passwordField"
                                               promptText="Enter account password"
                                               prefHeight="40.0"
                                               styleClass="management-field"/>
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Contact Number"
                                       styleClass="field-label"/>

                                <TextField fx:id="contactField"
                                           promptText="Example: 09123456789"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Assigned Room"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="roomComboBox"
                                          promptText="Select an available room"
                                          prefHeight="40.0"
                                          maxWidth="Infinity"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Current Balance"
                                       styleClass="field-label"/>

                                <TextField fx:id="balanceField"
                                           promptText="Enter current balance"
                                           prefHeight="40.0"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="NEVER">

                                <Label text="Account Status"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="statusComboBox"
                                          promptText="Select tenant status"
                                          prefHeight="40.0"
                                          maxWidth="Infinity"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <Label fx:id="formMessageLabel"
                               text=""
                               wrapText="true"
                               minHeight="18.0"
                               styleClass="form-message-label"/>

                        <HBox alignment="CENTER_RIGHT"
                              spacing="10.0">

                            <Button text="Clear"
                                    onAction="#handleClear"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Delete"
                                    onAction="#handleDeleteTenant"
                                    prefHeight="40.0"
                                    styleClass="danger-button"/>

                            <Button text="Update"
                                    onAction="#handleUpdateTenant"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Add Tenant"
                                    onAction="#handleAddTenant"
                                    prefHeight="40.0"
                                    styleClass="primary-button"/>

                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
