<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" styleClass="management-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cabiso_capstone.controllers.TenantController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="dashboard-header">

            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>

            <VBox spacing="2.0">
                <Label styleClass="dashboard-brand" text="CABANA DORMITORY" />

                <Label styleClass="dashboard-brand-subtitle" text="Dormitory Management System" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER_RIGHT" spacing="2.0">

                <Label styleClass="dashboard-user" text="Administrator" />

                <Label styleClass="dashboard-user-role" text="System Manager" />
            </VBox>

        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="8.0" styleClass="dashboard-sidebar">

            <padding>
                <Insets bottom="22.0" left="15.0" right="15.0" top="28.0" />
            </padding>

            <Label styleClass="sidebar-title" text="MAIN MENU" />

            <Button maxWidth="Infinity" onAction="#openDashboard" styleClass="sidebar-button" text="Dashboard" />

            <Button maxWidth="Infinity" styleClass="sidebar-button-active" text="Tenant Management" />

            <Button maxWidth="Infinity" onAction="#openRoomView" styleClass="sidebar-button" text="Room Management" />

            <Button maxWidth="Infinity" onAction="#openPaymentView" styleClass="sidebar-button" text="Payment Management" />

            <Region VBox.vgrow="ALWAYS" />

            <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="logout-button" text="Logout" />

        </VBox>
    </left>

    <center>
        <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="management-scroll-pane">

            <content>
                <VBox spacing="40.0" styleClass="management-content">

                    <padding>
                        <Insets bottom="35.0" left="32.0" right="32.0" top="30.0" />
                    </padding>

                    <VBox spacing="4.0">
                        <Label styleClass="dashboard-title" text="Tenant Management" />

                        <Label styleClass="dashboard-subtitle" text="View, register, update, and manage dormitory tenants." />
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar-card">

                        <TextField fx:id="searchField" prefHeight="40.0" promptText="Search by tenant name, username, or room..." styleClass="management-field" HBox.hgrow="ALWAYS" />

                        <Button onAction="#handleSearch" prefHeight="40.0" styleClass="secondary-button" text="Search" />

                        <Button onAction="#handleRefresh" prefHeight="40.0" styleClass="secondary-button" text="Refresh" />
                    </HBox>

                    <VBox prefHeight="164.0" prefWidth="799.0" spacing="12.0" styleClass="content-card" VBox.vgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3.0">
                                <Label styleClass="section-title" text="Tenant Records" />

                                <Label styleClass="section-description" text="Select a tenant record to view or update its information." />
                            </VBox>

                            <Region HBox.hgrow="ALWAYS" />

                            <Label fx:id="recordCountLabel" styleClass="record-count-label" text="0 records" />
                        </HBox>

                        <TableView fx:id="tenantTable" prefHeight="400.0" styleClass="management-table" VBox.vgrow="ALWAYS">

                            <placeholder>
                                <Label styleClass="table-placeholder" text="No tenant records available." />
                            </placeholder>

                            <columns>
                                <TableColumn fx:id="tenantIdColumn" prefWidth="65.0" text="ID" />

                                <TableColumn fx:id="fullNameColumn" prefWidth="180.0" text="Full Name" />

                                <TableColumn fx:id="usernameColumn" prefWidth="125.0" text="Username" />

                                <TableColumn fx:id="contactColumn" prefWidth="145.0" text="Contact Number" />

                                <TableColumn fx:id="roomColumn" prefWidth="90.0" text="Room" />

                                <TableColumn fx:id="balanceColumn" prefWidth="120.0" text="Balance" />

                                <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                            </columns>

                        </TableView>
                    </VBox>

                    <VBox spacing="16.0" styleClass="content-card">

                        <VBox spacing="3.0">
                            <Label styleClass="section-title" text="Tenant Information" />

                            <Label styleClass="section-description" text="Complete the required fields before saving a tenant record." />
                        </VBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Tenant ID" />

                                <TextField fx:id="tenantIdField" editable="false" prefHeight="40.0" promptText="Generated automatically" styleClass="management-field-disabled" />
                            </VBox>

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Full Name" />

                                <TextField fx:id="fullNameField" prefHeight="40.0" promptText="Enter tenant's full name" styleClass="management-field" />
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Username" />

                                <TextField fx:id="usernameField" prefHeight="40.0" promptText="Enter account username" styleClass="management-field" />
                            </VBox>

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Password" />

                                <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Enter account password" styleClass="management-field" />
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Contact Number" />

                                <TextField fx:id="contactField" prefHeight="40.0" promptText="Example: 09123456789" styleClass="management-field" />
                            </VBox>

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Assigned Room" />

                                <ComboBox fx:id="roomComboBox" maxWidth="Infinity" prefHeight="40.0" promptText="Select an available room" styleClass="management-combo-box" />
                            </VBox>

                        </HBox>

                        <HBox spacing="16.0">

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Current Balance" />

                                <TextField fx:id="balanceField" prefHeight="40.0" promptText="Enter current balance" styleClass="management-field" />
                            </VBox>

                            <VBox spacing="6.0" HBox.hgrow="NEVER">

                                <Label styleClass="field-label" text="Account Status" />

                                <ComboBox fx:id="statusComboBox" maxWidth="Infinity" prefHeight="40.0" promptText="Select tenant status" styleClass="management-combo-box" />
                            </VBox>

                        </HBox>

                        <Label fx:id="formMessageLabel" minHeight="18.0" styleClass="form-message-label" text="" wrapText="true" />

<!--                        <HBox alignment="CENTER_RIGHT" spacing="10.0">-->

<!--                            <Button onAction="#handleClear" prefHeight="40.0" styleClass="secondary-button" text="Clear" />-->

<!--                            <Button onAction="#handleDeleteTenant" prefHeight="40.0" styleClass="danger-button" text="Delete" />-->

<!--                            <Button onAction="#handleUpdateTenant" prefHeight="40.0" styleClass="secondary-button" text="Update" />-->

<!--                            <Button onAction="#handleAddTenant" prefHeight="40.0" styleClass="primary-button" text="Add Tenant" />-->

<!--                        </HBox>-->
                        <HBox alignment="CENTER_RIGHT"
                              spacing="10.0">

                            <Button text="Clear"
                                    onAction="#handleClear"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Delete"
                                    onAction="#handleDeleteTenant"
                                    prefHeight="40.0"
                                    styleClass="danger-button"/>

                            <Button text="Update"
                                    onAction="#handleUpdateTenant"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Approve"
                                    onAction="#handleApproveTenant"
                                    prefHeight="40.0"
                                    styleClass="primary-button"/>

                            <Button text="Add Tenant"
                                    onAction="#handleAddTenant"
                                    prefHeight="40.0"
                                    styleClass="primary-button"/>

                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
