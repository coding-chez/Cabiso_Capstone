<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1440.0"
            prefHeight="900.0" styleClass="management-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cabiso_capstone.controllers.TenantController">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15.0"
              styleClass="dashboard-header">

            <padding>
                <Insets top="15.0" right="25.0" bottom="15.0" left="25.0"/>
            </padding>

            <VBox spacing="2.0">
                <Label text="CABANA DORMITORY"
                       styleClass="dashboard-brand"/>

                <Label text="Dormitory Management System"
                       styleClass="dashboard-brand-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2.0">

                <Label text="Administrator"
                       styleClass="dashboard-user"/>

                <Label text="System Manager"
                       styleClass="dashboard-user-role"/>
            </VBox>

        </HBox>
    </top>

    <left>
        <VBox spacing="8.0"
              styleClass="dashboard-sidebar">

            <padding>
                <Insets top="28.0" right="15.0" bottom="22.0" left="15.0"/>
            </padding>

            <Label text="MAIN MENU"
                   styleClass="sidebar-title"/>

            <Button text="Dashboard"
                    maxWidth="Infinity"
                    onAction="#openDashboard"
                    styleClass="sidebar-button"/>

            <Button text="Tenant Management"
                    maxWidth="Infinity"
                    styleClass="sidebar-button-active"/>

            <Button text="Room Management"
                    maxWidth="Infinity"
                    onAction="#openRoomView"
                    styleClass="sidebar-button"/>

            <Button text="Payment Management"
                    maxWidth="Infinity"
                    onAction="#openPaymentView"
                    styleClass="sidebar-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout"
                    maxWidth="Infinity"
                    onAction="#handleLogout"
                    styleClass="logout-button"/>

        </VBox>
    </left>

    <center>
        <ScrollPane fitToHeight="false"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    styleClass="management-scroll-pane">

            <content>
                <VBox spacing="20.0"
                      styleClass="management-content">

                    <padding>
                        <Insets top="30.0" right="32.0" bottom="35.0" left="32.0"/>
                    </padding>

                    <!-- Page title -->
                    <VBox spacing="4.0">
                        <Label text="Tenant Management"
                               styleClass="dashboard-title"/>

                        <Label text="Review applications, manage tenant records, and update account information."
                               styleClass="dashboard-subtitle"/>
                    </VBox>

                    <!-- Search toolbar -->
                    <HBox alignment="CENTER_LEFT"
                          spacing="10.0"
                          styleClass="toolbar-card">

                        <TextField fx:id="searchField"
                                   prefHeight="40.0"
                                   promptText="Search by tenant name, username, contact, or room..."
                                   styleClass="management-field"
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="statusFilterComboBox"
                                  prefHeight="40.0"
                                  prefWidth="155.0"
                                  promptText="All Statuses"
                                  styleClass="management-combo-box"/>

                        <Button text="Search"
                                onAction="#handleSearch"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>

                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefHeight="40.0"
                                styleClass="secondary-button"/>
                    </HBox>

                    <!-- Tenant records -->
                    <VBox minHeight="320.0"
                          prefHeight="340.0"
                          maxHeight="340.0"
                          spacing="16.0"
                          styleClass="content-card">

                        <HBox alignment="CENTER_LEFT">

                            <VBox spacing="3.0">
                                <Label text="Tenant Records"
                                       styleClass="section-title"/>

                                <Label text="Select a tenant record to review or update its information."
                                       styleClass="section-description"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label fx:id="recordCountLabel"
                                   text="0 records"
                                   styleClass="record-count-label"/>
                        </HBox>

                        <TableView fx:id="tenantTable"
                                   minHeight="235.0"
                                   prefHeight="235.0"
                                   maxHeight="235.0"
                                   styleClass="management-table">

                            <placeholder>
                                <Label text="No tenant records available."
                                       styleClass="table-placeholder"/>
                            </placeholder>

                            <columns>
                                <TableColumn fx:id="tenantIdColumn"
                                             text="ID"/>

                                <TableColumn fx:id="fullNameColumn"
                                             text="Full Name"/>

                                <TableColumn fx:id="usernameColumn"
                                             text="Username"/>

                                <TableColumn fx:id="contactColumn"
                                             text="Contact Number"/>

                                <TableColumn fx:id="roomColumn"
                                             text="Room"/>

                                <TableColumn fx:id="balanceColumn"
                                             text="Balance"/>

                                <TableColumn fx:id="statusColumn"
                                             text="Status"/>
                            </columns>

                        </TableView>
                    </VBox>

                    <!-- Tenant information -->
                    <VBox spacing="20.0"
                          styleClass="content-card">

                        <VBox spacing="3.0">
                            <Label text="Tenant Information"
                                   styleClass="section-title"/>

                            <Label text="Select a record above, then review or update the tenant information."
                                   styleClass="section-description"/>
                        </VBox>

                        <!-- Row 1 -->
                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Tenant ID"
                                       styleClass="field-label"/>

                                <TextField fx:id="tenantIdField"
                                           editable="false"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Generated automatically"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Full Name"
                                       styleClass="field-label"/>

                                <TextField fx:id="fullNameField"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Enter tenant's full name"
                                           styleClass="management-field"/>
                            </VBox>

                        </HBox>

                        <!-- Row 2 -->
                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Username"
                                       styleClass="field-label"/>

                                <TextField fx:id="usernameField"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Enter account username"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Password"
                                       styleClass="field-label"/>

                                <PasswordField fx:id="passwordField"
                                               maxWidth="Infinity"
                                               prefHeight="40.0"
                                               promptText="Enter account password"
                                               styleClass="management-field"/>
                            </VBox>

                        </HBox>

                        <!-- Row 3 -->
                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Contact Number"
                                       styleClass="field-label"/>

                                <TextField fx:id="contactField"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Example: 09123456789"
                                           styleClass="management-field"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Assigned Room"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="roomComboBox"
                                          maxWidth="Infinity"
                                          prefHeight="40.0"
                                          promptText="Select an available room"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <!-- Row 4 -->
                        <HBox spacing="16.0">

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Current Balance"
                                       styleClass="field-label"/>

                                <TextField fx:id="balanceField"
                                           editable="false"
                                           maxWidth="Infinity"
                                           prefHeight="40.0"
                                           promptText="Calculated automatically"
                                           styleClass="management-field-disabled"/>
                            </VBox>

                            <VBox spacing="6.0"
                                  HBox.hgrow="ALWAYS">

                                <Label text="Account Status"
                                       styleClass="field-label"/>

                                <ComboBox fx:id="statusComboBox"
                                          maxWidth="Infinity"
                                          prefHeight="40.0"
                                          promptText="Select tenant status"
                                          styleClass="management-combo-box"/>
                            </VBox>

                        </HBox>

                        <Label fx:id="formMessageLabel"
                               minHeight="18.0"
                               text=""
                               wrapText="true"
                               styleClass="form-message-label"/>

                        <!-- Actions -->
                        <HBox alignment="CENTER_RIGHT"
                              spacing="10.0">

                            <Button text="Clear"
                                    onAction="#handleClear"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Deactivate"
                                    onAction="#handleDeactivateTenant"
                                    prefHeight="40.0"
                                    styleClass="danger-button"/>

                            <Button text="Update"
                                    onAction="#handleUpdateTenant"
                                    prefHeight="40.0"
                                    styleClass="secondary-button"/>

                            <Button text="Approve Tenant"
                                    onAction="#handleApproveTenant"
                                    prefHeight="40.0"
                                    styleClass="primary-button"/>

                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>