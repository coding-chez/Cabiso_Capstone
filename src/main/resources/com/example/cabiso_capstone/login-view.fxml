<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="1440.0"
            prefHeight="900.0"
            stylesheets="@styles.css"
            styleClass="root-container"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cabiso_capstone.controllers.LoginController">

    <children>

        <HBox AnchorPane.topAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0">

            <!-- LEFT BRANDING PANEL -->

            <VBox alignment="CENTER_LEFT"
                  prefWidth="500.0"
                  spacing="22.0"
                  styleClass="welcome-panel">

                <padding>
                    <Insets top="65.0"
                            right="60.0"
                            bottom="45.0"
                            left="60.0"/>
                </padding>

                <ImageView fitWidth="155.0"
                           fitHeight="155.0"
                           preserveRatio="true"
                           smooth="true"
                           styleClass="auth-logo">

                    <image>
                        <Image url="@CABANA.png"/>
                    </image>

                </ImageView>

                <Region prefHeight="4.0"/>

                <Label text="CABANA DORMITORY"
                       styleClass="brand-name"/>

                <Label text="Dormitory&#10;Management System"
                       maxWidth="390.0"
                       wrapText="true"
                       styleClass="welcome-title"/>

                <Label text="Securely manage tenants, rooms, and payments through one centralized platform."
                       maxWidth="365.0"
                       wrapText="true"
                       styleClass="welcome-description"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Label text="Built with JavaFX • MySQL • Java"
                       styleClass="welcome-footer"/>

                <Label text="© 2026 CABANA Dormitory Management System"
                       styleClass="welcome-footer"/>

            </VBox>

            <!-- RIGHT LOGIN AREA -->

            <VBox alignment="CENTER"
                  styleClass="login-section"
                  HBox.hgrow="ALWAYS">

                <padding>
                    <Insets top="40.0"
                            right="90.0"
                            bottom="40.0"
                            left="40.0"/>
                </padding>

                <VBox prefWidth="420.0"
                      maxWidth="420.0"
                      spacing="15.0"
                      styleClass="login-card">

                    <padding>
                        <Insets top="42.0"
                                right="42.0"
                                bottom="38.0"
                                left="42.0"/>
                    </padding>

                    <Label text="Welcome Back"
                           styleClass="login-title"/>

                    <Label text="Enter your account credentials to continue."
                           wrapText="true"
                           styleClass="login-subtitle"/>

                    <Region prefHeight="14.0"/>

                    <Label text="Username"
                           styleClass="field-label"/>

                    <TextField fx:id="usernameField"
                               prefHeight="44.0"
                               promptText="Enter username"
                               styleClass="login-field"/>

                    <Label text="Password"
                           styleClass="field-label"/>

                    <PasswordField fx:id="passwordField"
                                   prefHeight="44.0"
                                   promptText="Enter password"
                                   onAction="#handleLogin"
                                   styleClass="login-field"/>

                    <Label fx:id="messageLabel"
                           text=""
                           minHeight="22.0"
                           wrapText="true"
                           styleClass="message-label"/>

                    <Button text="LOGIN"
                            maxWidth="Infinity"
                            prefHeight="46.0"
                            onAction="#handleLogin"
                            styleClass="login-button"/>

                    <HBox alignment="CENTER"
                          spacing="5.0">

                        <Label text="Don't have an account?"
                               styleClass="login-note"/>

                        <Hyperlink text="Register as Tenant"
                                   onAction="#openRegisterView"
                                   styleClass="register-link"/>

                    </HBox>

                </VBox>

            </VBox>

        </HBox>

    </children>

</AnchorPane>