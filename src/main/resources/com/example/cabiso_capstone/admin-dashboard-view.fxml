<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" styleClass="dashboard-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cabiso_capstone.controllers.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="dashboard-header">

            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>

            <VBox spacing="2.0">
                <Label styleClass="dashboard-brand" text="CABANA DORMITORY" />

                <Label styleClass="dashboard-brand-subtitle" text="Dormitory Management System" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER_RIGHT" spacing="2.0">

                <Label fx:id="adminNameLabel" styleClass="dashboard-user" text="Administrator" />

                <Label styleClass="dashboard-user-role" text="System Manager" />
            </VBox>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="8.0" styleClass="dashboard-sidebar">

            <padding>
                <Insets bottom="22.0" left="15.0" right="15.0" top="28.0" />
            </padding>

            <Label styleClass="sidebar-title" text="MAIN MENU" />

            <Button fx:id="dashboardButton" maxWidth="Infinity" onAction="#showDashboard" styleClass="sidebar-button-active" text="Dashboard" />

            <Button maxWidth="Infinity" onAction="#openTenantView" styleClass="sidebar-button" text="Tenant Management" />

            <Button maxWidth="Infinity" onAction="#openRoomView" styleClass="sidebar-button" text="Room Management" />

            <Button maxWidth="Infinity" onAction="#openPaymentView" styleClass="sidebar-button" text="Payment Management" />

            <Region VBox.vgrow="ALWAYS" />

            <Separator styleClass="sidebar-separator" />

            <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="logout-button" text="Logout" />

        </VBox>
    </left>
    <center>
        <VBox spacing="24.0" styleClass="dashboard-content">

            <padding>
                <Insets bottom="35.0" left="35.0" right="35.0" top="32.0" />
            </padding>
            <VBox spacing="5.0">

                <Label styleClass="dashboard-title" text="Administrator Dashboard" />

                <Label styleClass="dashboard-subtitle" text="View the dormitory overview and access management modules." />

            </VBox>
            <HBox spacing="18.0">

                <VBox spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">

                    <Label styleClass="summary-label" text="TOTAL TENANTS" />

                    <Label fx:id="totalTenantsLabel" styleClass="summary-value" text="0" />

                    <Label styleClass="summary-description" text="Registered tenant accounts" />

                </VBox>

                <VBox spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">

                    <Label styleClass="summary-label" text="AVAILABLE ROOMS" />

                    <Label fx:id="availableRoomsLabel" styleClass="summary-value" text="0" />

                    <Label styleClass="summary-description" text="Rooms ready for occupancy" />

                </VBox>

                <VBox spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">

                    <Label styleClass="summary-label" text="PENDING PAYMENTS" />

                    <Label fx:id="pendingPaymentsLabel" styleClass="summary-value" text="0" />

                    <Label styleClass="summary-description" text="Payment records requiring attention" />

                </VBox>

            </HBox>
            <VBox spacing="15.0" styleClass="content-card">

                <VBox spacing="3.0">
                    <Label styleClass="section-title" text="Quick Access" />

                    <Label styleClass="section-description" text="Choose a module to begin managing dormitory information." />
                </VBox>

                <HBox spacing="12.0">

                    <Button onAction="#openTenantView" prefHeight="40.0" styleClass="quick-action-button" text="Manage Tenants" />

                    <Button onAction="#openRoomView" prefHeight="40.0" styleClass="quick-action-button" text="Manage Rooms" />

                    <Button onAction="#openPaymentView" prefHeight="40.0" styleClass="quick-action-button" text="Manage Payments" />

                </HBox>

            </VBox>
            <VBox spacing="15.0" styleClass="content-card">

                <VBox spacing="3.0">
                    <Label styleClass="section-title" text="System Information" />

                    <Label styleClass="section-description" text="Current dormitory management summary." />
                </VBox>

                <Separator />

                <HBox spacing="50.0">

                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label" text="Occupied Rooms" />

                        <Label fx:id="occupiedRoomsLabel" styleClass="detail-value" text="0" />
                    </VBox>

                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label" text="Total Rooms" />

                        <Label fx:id="totalRoomsLabel" styleClass="detail-value" text="0" />
                    </VBox>

                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label" text="Recorded Payments" />

                        <Label fx:id="totalPaymentsLabel" styleClass="detail-value" text="0" />
                    </VBox>

                </HBox>

            </VBox>

        </VBox>
    </center>

</BorderPane>
