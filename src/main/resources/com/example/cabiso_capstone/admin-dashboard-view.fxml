<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.ImageView?>
<BorderPane prefWidth="1440.0" prefHeight="900.0" styleClass="dashboard-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cabiso_capstone.controllers.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="14.0"
              styleClass="dashboard-header">

            <padding>
                <Insets top="12.0"
                        right="28.0"
                        bottom="12.0"
                        left="25.0"/>
            </padding>

            <ImageView fitWidth="48.0"
                       fitHeight="48.0"
                       preserveRatio="true"
                       smooth="true"
                       styleClass="header-logo">

                <image>
                    <Image url="@CABANA.png"/>
                </image>

            </ImageView>

            <VBox spacing="2.0">

                <Label text="CABANA DORMITORY"
                       styleClass="dashboard-brand"/>

                <Label text="Dormitory Management System"
                       styleClass="dashboard-brand-subtitle"/>

            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2.0">

                <Label fx:id="adminNameLabel"
                       text="Administrator"
                       styleClass="dashboard-user"/>

                <Label text="System Manager"
                       styleClass="dashboard-user-role"/>

            </VBox>

            <Separator orientation="VERTICAL"
                       prefHeight="36.0"
                       styleClass="header-separator"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2.0">

                <Label fx:id="currentDateLabel"
                       text="July 20, 2026"
                       styleClass="dashboard-date"/>

                <Label fx:id="currentTimeLabel"
                       text="10:30 AM"
                       styleClass="dashboard-time"/>

            </VBox>

        </HBox>

    </top>

    <left>

        <VBox prefWidth="220.0"
              spacing="8.0"
              styleClass="dashboard-sidebar">

            <padding>
                <Insets top="28.0"
                        right="15.0"
                        bottom="22.0"
                        left="15.0"/>
            </padding>

            <Label text="MAIN MENU"
                   styleClass="sidebar-title"/>

            <Button fx:id="dashboardButton"
                    text="Dashboard"
                    maxWidth="Infinity"
                    prefHeight="43.0"
                    onAction="#showDashboard"
                    styleClass="sidebar-button-active"/>

            <Button text="Tenant Management"
                    maxWidth="Infinity"
                    prefHeight="43.0"
                    onAction="#openTenantView"
                    styleClass="sidebar-button"/>

            <Button text="Room Management"
                    maxWidth="Infinity"
                    prefHeight="43.0"
                    onAction="#openRoomView"
                    styleClass="sidebar-button"/>

            <Button text="Payment Management"
                    maxWidth="Infinity"
                    prefHeight="43.0"
                    onAction="#openPaymentView"
                    styleClass="sidebar-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-separator"/>

            <Button text="Logout"
                    maxWidth="Infinity"
                    prefHeight="43.0"
                    onAction="#handleLogout"
                    styleClass="logout-button"/>

        </VBox>

    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="false"
                    pannable="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="dashboard-scroll">
                <content>
        <VBox spacing="24.0" styleClass="dashboard-content">

            <padding>
                <Insets bottom="35.0" left="35.0" right="35.0" top="32.0" />
            </padding>
            <VBox spacing="5.0">

                <Label styleClass="dashboard-title" text="Welcome back, Admin!" />


                <Label styleClass="dashboard-subtitle" text="Here's today's dormitory activity summary." />

            </VBox>
            <HBox spacing="18.0">

                <VBox spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">

                    <Label styleClass="summary-label" text="TOTAL TENANTS" />

                    <Label fx:id="totalTenantsLabel" styleClass="summary-value" text="0" />

                    <Label styleClass="summary-description" text="Registered tenant accounts" />

                </VBox>

                <VBox spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">

                    <Label styleClass="summary-label" text="AVAILABLE ROOMS" />

                    <Label fx:id="availableRoomsLabel" styleClass="summary-value" text="0" />

                    <Label styleClass="summary-description" text="Rooms ready for occupancy" />

                </VBox>

                <VBox spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">

                    <Label styleClass="summary-label"
                           text="PAID PAYMENTS" />

                    <Label fx:id="pendingPaymentsLabel"
                           styleClass="summary-value"
                           text="0" />

                    <Label styleClass="summary-description"
                           text="Successfully recorded payments" />

                </VBox>

            </HBox>
            <VBox spacing="15.0" styleClass="content-card">

                <VBox spacing="3.0">
                    <Label styleClass="section-title" text="Quick Access" />

                    <Label styleClass="section-description" text="Choose a module to begin managing dormitory information." />
                </VBox>

                <HBox spacing="12.0">

                    <Button onAction="#openTenantView"
                            prefHeight="40.0"
                            styleClass="quick-action-button"
                            text="Manage Tenants" />

                    <Button onAction="#openRoomView"
                            prefHeight="40.0"
                            styleClass="quick-action-button"
                            text="Manage Rooms" />

                    <Button onAction="#openPaymentView"
                            prefHeight="40.0"
                            styleClass="quick-action-button"
                            text="Manage Payments" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button onAction="#handleRefreshDashboard"
                            prefHeight="40.0"
                            styleClass="secondary-button"
                            text="Refresh Dashboard" />

                </HBox>

            </VBox>
            <!-- OCCUPANCY SUMMARY -->

            <VBox spacing="15.0" styleClass="content-card">

                <VBox spacing="3.0">
                    <Label styleClass="section-title"
                           text="Occupancy Summary" />

                    <Label styleClass="section-description"
                           text="Current bed capacity and dormitory occupancy." />
                </VBox>

                <Separator />

                <HBox spacing="35.0">

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Occupied Rooms" />

                        <Label fx:id="occupiedRoomsLabel"
                               styleClass="detail-value"
                               text="0" />
                    </VBox>

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Total Rooms" />

                        <Label fx:id="totalRoomsLabel"
                               styleClass="detail-value"
                               text="0" />
                    </VBox>

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Occupied Beds" />

                        <Label fx:id="occupiedBedsLabel"
                               styleClass="detail-value"
                               text="0" />
                    </VBox>

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Available Slots" />

                        <Label fx:id="availableSlotsLabel"
                               styleClass="detail-value"
                               text="0" />
                    </VBox>

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Occupancy Rate" />

                        <Label fx:id="occupancyRateLabel"
                               styleClass="detail-value"
                               text="0%" />
                    </VBox>

                </HBox>

            </VBox>

            <!-- FINANCIAL SUMMARY -->

            <VBox spacing="15.0"
                  styleClass="content-card">

                <VBox spacing="3.0">

                    <Label styleClass="section-title"
                           text="Financial Summary" />

                    <Label styleClass="section-description"
                           text="Overview of successfully recorded and voided payments." />

                </VBox>

                <Separator />

                <HBox spacing="35.0">

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Current Month Revenue" />

                        <Label fx:id="monthlyRevenueLabel"
                               styleClass="detail-value"
                               text="₱0.00" />
                    </VBox>

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Total Revenue" />

                        <Label fx:id="totalRevenueLabel"
                               styleClass="detail-value"
                               text="₱0.00" />
                    </VBox>

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Paid Transactions" />

                        <Label fx:id="totalPaymentsLabel"
                               styleClass="detail-value"
                               text="0" />
                    </VBox>

                    <VBox spacing="4.0"
                          HBox.hgrow="ALWAYS">

                        <Label styleClass="detail-label"
                               text="Voided Transactions" />

                        <Label fx:id="voidPaymentsLabel"
                               styleClass="detail-value"
                               text="0" />
                    </VBox>

                </HBox>

            </VBox>

            <!-- RECENT ACTIVITY -->

            <HBox spacing="20.0">

                <!-- RECENT TENANTS -->

                <VBox spacing="14.0"
                      styleClass="content-card"
                      HBox.hgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT">

                        <VBox spacing="3.0">
                            <Label text="Recent Tenant Activity"
                                   styleClass="section-title"/>

                            <Label text="Latest tenant registrations and account statuses."
                                   styleClass="section-description"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="View All Tenants"
                                onAction="#openTenantView"
                                styleClass="secondary-button"/>
                    </HBox>

                    <TableView fx:id="recentTenantTable"
                               minHeight="235.0"
                               prefHeight="235.0"
                               maxHeight="235.0"
                               styleClass="management-table">

                        <placeholder>
                            <Label text="No recent tenant activity."
                                   styleClass="table-placeholder"/>
                        </placeholder>

                        <columns>
                            <TableColumn fx:id="recentTenantNameColumn"
                                         text="Tenant"/>

                            <TableColumn fx:id="recentTenantRoomColumn"
                                         text="Room"/>

                            <TableColumn fx:id="recentTenantStatusColumn"
                                         text="Status"/>
                        </columns>

                    </TableView>

                </VBox>

                <!-- RECENT PAYMENTS -->

                <VBox spacing="14.0"
                      styleClass="content-card"
                      HBox.hgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT">

                        <VBox spacing="3.0">
                            <Label text="Recent Payment Activity"
                                   styleClass="section-title"/>

                            <Label text="Latest recorded and voided tenant payments."
                                   styleClass="section-description"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="View All Payments"
                                onAction="#openPaymentView"
                                styleClass="secondary-button"/>
                    </HBox>

                    <TableView fx:id="recentPaymentTable"
                               minHeight="235.0"
                               prefHeight="235.0"
                               maxHeight="235.0"
                               styleClass="management-table">

                        <placeholder>
                            <Label text="No recent payment activity."
                                   styleClass="table-placeholder"/>
                        </placeholder>

                        <columns>
                            <TableColumn fx:id="recentPaymentTenantColumn"
                                         text="Tenant"/>

                            <TableColumn fx:id="recentPaymentAmountColumn"
                                         text="Amount"/>

                            <TableColumn fx:id="recentPaymentDateColumn"
                                         text="Date"/>

                            <TableColumn fx:id="recentPaymentStatusColumn"
                                         text="Status"/>
                        </columns>

                    </TableView>

                </VBox>

            </HBox>

        </VBox>
                </content>
        </ScrollPane>
    </center>

</BorderPane>
