<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="1440.0"
            prefHeight="900.0"
            stylesheets="@styles.css"
            styleClass="root-container"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cabiso_capstone.controllers.RegisterController">

    <children>

        <HBox AnchorPane.topAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0">

            <!-- LEFT BRANDING PANEL -->

            <VBox alignment="CENTER_LEFT"
                  prefWidth="500.0"
                  spacing="22.0"
                  styleClass="welcome-panel">

                <padding>
                    <Insets top="65.0"
                            right="60.0"
                            bottom="45.0"
                            left="60.0"/>
                </padding>

                <ImageView fitWidth="155.0"
                           fitHeight="155.0"
                           preserveRatio="true"
                           smooth="true"
                           styleClass="auth-logo">

                    <image>
                        <Image url="@CABANA.png"/>
                    </image>

                </ImageView>

                <Region prefHeight="4.0"/>

                <Label text="CABANA DORMITORY"
                       styleClass="brand-name"/>

                <Label text="Begin Your Stay&#10;With Us"
                       maxWidth="390.0"
                       wrapText="true"
                       styleClass="welcome-title"/>

                <Label text="Create your tenant account and submit your application for administrator approval."
                       maxWidth="365.0"
                       wrapText="true"
                       styleClass="welcome-description"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Label text="Simple registration • Secure account access"
                       styleClass="welcome-footer"/>

                <Label text="© 2026 CABANA Dormitory Management System"
                       styleClass="welcome-footer"/>

            </VBox>

            <!-- RIGHT REGISTRATION AREA -->

            <VBox alignment="CENTER"
                  styleClass="login-section"
                  HBox.hgrow="ALWAYS">

                <padding>
                    <Insets top="35.0"
                            right="90.0"
                            bottom="35.0"
                            left="40.0"/>
                </padding>

                <ScrollPane fitToWidth="true"
                            fitToHeight="false"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            prefWidth="460.0"
                            maxWidth="460.0"
                            maxHeight="800.0"
                            styleClass="register-scroll-pane">

                    <content>

                        <VBox prefWidth="440.0"
                              maxWidth="440.0"
                              spacing="13.0"
                              styleClass="login-card">

                            <padding>
                                <Insets top="38.0"
                                        right="42.0"
                                        bottom="36.0"
                                        left="42.0"/>
                            </padding>

                            <Label text="Tenant Registration"
                                   styleClass="login-title"/>

                            <Label text="Create an account to submit your tenant application."
                                   wrapText="true"
                                   styleClass="login-subtitle"/>

                            <Region prefHeight="8.0"/>

                            <Label text="Full Name"
                                   styleClass="field-label"/>

                            <TextField fx:id="fullNameField"
                                       prefHeight="44.0"
                                       promptText="Enter full name"
                                       styleClass="login-field"/>

                            <Label text="Contact Number"
                                   styleClass="field-label"/>

                            <TextField fx:id="contactNumberField"
                                       prefHeight="44.0"
                                       promptText="Enter contact number"
                                       styleClass="login-field"/>

                            <Label text="Username"
                                   styleClass="field-label"/>

                            <TextField fx:id="usernameField"
                                       prefHeight="44.0"
                                       promptText="Create username"
                                       styleClass="login-field"/>

                            <Label text="Password"
                                   styleClass="field-label"/>

                            <PasswordField fx:id="passwordField"
                                           prefHeight="44.0"
                                           promptText="Create password"
                                           styleClass="login-field"/>

                            <Label text="Confirm Password"
                                   styleClass="field-label"/>

                            <PasswordField fx:id="confirmPasswordField"
                                           prefHeight="44.0"
                                           promptText="Confirm password"
                                           onAction="#handleRegister"
                                           styleClass="login-field"/>

                            <Label fx:id="messageLabel"
                                   text=""
                                   minHeight="22.0"
                                   wrapText="true"
                                   styleClass="message-label"/>

                            <Button text="REGISTER"
                                    maxWidth="Infinity"
                                    prefHeight="46.0"
                                    onAction="#handleRegister"
                                    styleClass="login-button"/>

                            <HBox alignment="CENTER"
                                  spacing="5.0">

                                <Label text="Already have an account?"
                                       styleClass="login-note"/>

                                <Hyperlink text="Back to Login"
                                           onAction="#handleBackToLogin"
                                           styleClass="register-link"/>

                            </HBox>

                        </VBox>

                    </content>

                </ScrollPane>

            </VBox>

        </HBox>

    </children>

</AnchorPane>