<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<!--        prefHeight="650.0"-->
<!--        prefWidth="900.0"-->
<AnchorPane prefWidth="1440.0"
            prefHeight="900.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cabiso_capstone.controllers.RegisterController"
            stylesheets="@styles.css"
            styleClass="root-container">

    <children>

        <HBox AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <VBox alignment="CENTER_LEFT"
                  prefWidth="480.0"
                  spacing="18.0"
                  styleClass="welcome-panel">

                <padding>
                    <Insets bottom="60.0"
                            left="55.0"
                            right="55.0"
                            top="60.0" />
                </padding>

                <Label styleClass="brand-name"
                       text="CABANA DORMITORY">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label styleClass="welcome-title"
                       text="Begin Your Stay With Us"
                       wrapText="true">
                    <font>
                        <Font size="25.0" />
                    </font>
                </Label>

                <Label maxWidth="350.0"
                       styleClass="welcome-description"
                       text="Submit your tenant registration and wait for administrator approval."
                       wrapText="true" />

                <Region VBox.vgrow="ALWAYS" />

            </VBox>

            <VBox alignment="CENTER"
                  styleClass="login-section"
                  HBox.hgrow="ALWAYS">

                <ScrollPane fitToWidth="true"
                            maxWidth="410.0"
                            styleClass="register-scroll-pane">

                    <content>

                        <VBox spacing="12.0"
                              styleClass="login-card">

                            <padding>
                                <Insets bottom="35.0"
                                        left="40.0"
                                        right="40.0"
                                        top="35.0" />
                            </padding>

                            <Label styleClass="login-title"
                                   text="Tenant Registration">
                                <font>
                                    <Font name="System Bold" size="20.0" />
                                </font>
                            </Label>

                            <Label styleClass="login-subtitle"
                                   text="Create an account to submit your tenant application."
                                   wrapText="true" />

                            <Region prefHeight="6.0" />

                            <Label styleClass="field-label"
                                   text="Full Name" />

                            <TextField fx:id="fullNameField"
                                       prefHeight="42.0"
                                       promptText="Enter full name"
                                       styleClass="login-field" />

                            <Label styleClass="field-label"
                                   text="Contact Number" />

                            <TextField fx:id="contactNumberField"
                                       prefHeight="42.0"
                                       promptText="Enter contact number"
                                       styleClass="login-field" />

                            <Label styleClass="field-label"
                                   text="Username" />

                            <TextField fx:id="usernameField"
                                       prefHeight="42.0"
                                       promptText="Create username"
                                       styleClass="login-field" />

                            <Label styleClass="field-label"
                                   text="Password" />

                            <PasswordField fx:id="passwordField"
                                           prefHeight="42.0"
                                           promptText="Create password"
                                           styleClass="login-field" />

                            <Label styleClass="field-label"
                                   text="Confirm Password" />

                            <PasswordField fx:id="confirmPasswordField"
                                           onAction="#handleRegister"
                                           prefHeight="42.0"
                                           promptText="Confirm password"
                                           styleClass="login-field" />

                            <Label fx:id="messageLabel"
                                   minHeight="20.0"
                                   styleClass="message-label"
                                   text=""
                                   wrapText="true" />

                            <Button maxWidth="Infinity"
                                    onAction="#handleRegister"
                                    prefHeight="44.0"
                                    styleClass="login-button"
                                    text="REGISTER" />

                            <HBox alignment="CENTER" spacing="4.0">

                                <Label styleClass="login-note"
                                       text="Already have an account?" />

                                <Hyperlink onAction="#handleBackToLogin"
                                           styleClass="register-link"
                                           text="Back to Login" />

                            </HBox>

                        </VBox>

                    </content>

                </ScrollPane>

            </VBox>

        </HBox>

    </children>

</AnchorPane>